{% extends 'base.html.twig' %}

{% block title %}Report index{% endblock %}

{% block body %}
    <h1>Report index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Description</th>
                <th>GravityLevel</th>
                <th>Status</th>
                <th>Latitude</th>
                <th>Longitude</th>
                <th>Address</th>
                <th>AudioUrl</th>
                <th>AudioLanguage</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for report in reports %}
            <tr>
                <td>{{ report.id }}</td>
                <td>{{ report.description }}</td>
                <td>{{ report.gravityLevel.value }}</td>
                <td>{{ report.status.value }}</td>
                <td>{{ report.latitude }}</td>
                <td>{{ report.longitude }}</td>
                <td>{{ report.address }}</td>
                <td>{{ report.audioUrl }}</td>
                <td>{{ report.audioLanguage }}</td>
                <td>{{ report.createdAt ? report.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ report.updatedAt ? report.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_report_show', {'id': report.id}) }}">show</a>
                    <a href="{{ path('app_report_edit', {'id': report.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_report_new') }}">Create new</a>
{% endblock %}
