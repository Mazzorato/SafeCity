{% extends 'base.html.twig' %}

{% block title %} Choisir ma ville {% endblock %}

{% block body %}


<div>
    <h1> Choisir ma ville </h1>

    {% for flash in app.flashes('success') %}
        <div> {{ flash }}</div>
    {% endfor %}

    <button type="button" disabled>Utiliser ma position GPS </button>

    <input type="text" id="citySearch" placeholder="Rechercher une ville...">

    <ul id="cityList">
        {% for city in cities %}
            <li class="city-item" data-city-name="{{ city.name|lower }}">
                <form action="{{ path ('app_city_choose', {id: city.id}) }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('choose_city') }}">
                    <button type="submit">
                        {{ city.name }} - {{ city.postalCode }}
                        {% if app.user.city and app.user.city.id == city.id %}
                            check
                        {% endif %}
                    </button>
                </form>
            </li>
        {% endfor %}
    </ul>
    </div>

    <script>
        document.getElementById('citySearch').addEventListener('input', function (e){
            const query = e.target.value.toLowerCase();
            document.querySelectorAll('.city-item').forEach(function (item) {
                const name = item.dataset.cityName;
                item.style.display = name.includes(query)? '' : 'none';
            });
        });
    </script>
    {% endblock %}
