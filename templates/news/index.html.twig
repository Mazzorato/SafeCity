{% extends 'base.html.twig' %}

{% block title %}Actualités{% endblock %}

{% block body %}
<div>
    <h1>Actualités</h1>
    <p>{{ city ? city.name ~ ' & Direct' : 'Aucune ville sélectionné' }}</p>

    <nav>
        <a href="{{ path('app_news', {category: 'all'}) }}" class="{{ category == 'all' ? 'active' : '' }}">Tout</a>
        <a href="{{ path('app_news', {category: 'securite'}) }}" class="{{ category == 'securite' ? 'active' : '' }}">Sécurité</a>
        <a href="{{ path('app_news', {category: 'sante'}) }}" class="{{ category == 'sante' ? 'active' : '' }}">Santé</a>
        <a href="{{ path('app_news', {category: 'mobilite'}) }}" class="{{ category == 'mobilite' ? 'active' : '' }}">Mobilité</a>
        <a href="{{ path('app_news', {category: 'travaux'}) }}" class="{{ category == 'travaux' ? 'active' : '' }}">Travaux</a>
    </nav>

    {% if featured %}
        <section class="featured-news">
            <span class="badge"> {{ featured.category.value }} </span>
            <h2> {{ featured.title }}</h2>
            <p>Il y a {{ featured.publishedAt|date('H\\hi') }} </p>
        </section>
    {% endif %}

    <h3>Dernières nouvelles </h3>

    {% if news is empty %}
        <p> Aucune actualité disponible pour votre ville pour le moment.</p>
    {% else %}
        <ul>
            {% for item in news %}
                <li>{{ item.category.value }}
                    {% if item.imageUrl %}
                        <img src="{{ item.imageUrl }}" alt="{{ item.title }}">
                    {% endif %}
                    <span class="badge"> {{ item.category.value }}</span>
                    <h4>{{ item.title }}</h4>
                    <p>{{ item.publishedAt|date('d/m/Y') }}</p>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}
